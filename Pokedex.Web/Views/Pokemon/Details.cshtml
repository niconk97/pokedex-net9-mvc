@model Pokedex.Dominio.Pokemon

@{
    ViewData["Title"] = "Detalle Pokemon";
}

<h1>Detalle Pokemon</h1>

<div>
    <hr />
    <div class="row">
        <div class="col-8">
            <dl class="row">
                <dt class="col-sm-2">
                    @Html.DisplayNameFor(model => model.Id)
                </dt>
                <dd class="col-sm-10">
                    @Html.DisplayFor(model => model.Id)
                </dd>
                <dt class="col-sm-2">
                    @Html.DisplayNameFor(model => model.Numero)
                </dt>
                <dd class="col-sm-10">
                    @Html.DisplayFor(model => model.Numero)
                </dd>
                <dt class="col-sm-2">
                    @Html.DisplayNameFor(model => model.Nombre)
                </dt>
                <dd class="col-sm-10">
                    @Html.DisplayFor(model => model.Nombre)
                </dd>
                <dt class="col-sm-2">
                    @Html.DisplayNameFor(model => model.Descripcion)
                </dt>
                <dd class="col-sm-10">
                    @Html.DisplayFor(model => model.Descripcion)
                </dd>
                <dt class="col-sm-2">
                    @* @Html.DisplayNameFor(model => model.UrlImagen) *@
                </dt>
                <dd class="col-sm-10">
                    @* @Html.DisplayFor(model => model.UrlImagen) *@
                </dd>
                <dt class="col-sm-2">
                    Tipo
                </dt>
                <dd class="col-sm-10">
                    @Html.DisplayFor(model => model.Tipo.Descripcion)
                </dd>
                <dt class="col-sm-2">
                    Debilidad
                </dt>
                <dd class="col-sm-10">
                    @Html.DisplayFor(model => model.Debilidad.Descripcion)
                </dd>
                <dt class="col-sm-2">
                    @Html.DisplayNameFor(model => model.Activo)
                </dt>
                <dd class="col-sm-10">
                    @Html.DisplayFor(model => model.Activo)
                </dd>
            </dl>

            <div class="row mb-3">
                <div class="col">
                    <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-primary">Editar</a>
                    <a asp-action="Index" class="btn btn-secondary">Volver al listado</a>
                </div>
            </div>

        </div>
        <div class="col-4 text-left">
            <img src="@Model.UrlImagen" alt="@Model.Nombre" class="img-fluid"/>
        </div>
    </div>
</div>

